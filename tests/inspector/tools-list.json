{
  "tools": [
    {
      "name": "docs",
      "description": "Run a bash command over the DocsVFS virtual filesystem. Mounts: /docs (read-only source documentation), /memory (persistent notes across sessions), /workspace (24h scratch). Supports ls, cd, cat, grep, find, tree, head, tail, wc, pipes (|), and redirects (>, >>). Writes to /docs return EROFS. Start with `tree / -L 2` to orient. Use `.` (not `/`) as the search path when cwd is / to avoid a double-slash bug in the underlying grep.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1,
            "description": "A bash command. One-line; semicolons and pipes allowed."
          }
        },
        "required": [
          "command"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "density",
      "description": "Rank files under <path> by occurrence count of <term>. Returns a ranked list with ASCII bars and a drill-in suggestion (e.g. \"→ /docs/FOO.md dominates. Try: cat /docs/FOO.md\"). Works across all mounts — pass `/` to scan /docs, /memory, and /workspace together. Faster than re-reading grep output when you just want to know where a term concentrates.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Root path to scan. Use `/` for all mounts."
          },
          "term": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Term to count. Literal substring match."
          },
          "caseInsensitive": {
            "description": "Case-insensitive match. Default false.",
            "type": "boolean"
          },
          "top": {
            "description": "Max rows returned. Default 10, max 100.",
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        },
        "required": [
          "path",
          "term"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "totalFiles": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "totalMatches": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "count": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "path",
                "count"
              ],
              "additionalProperties": false
            }
          },
          "suggestion": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "elapsedMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "term",
          "path",
          "totalFiles",
          "totalMatches",
          "rows",
          "suggestion",
          "elapsedMs"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "stats",
      "description": "Return per-mount file counts, total bytes, chunk-index size, last-write timestamp, and server boot time. Use at session start to see scale before deciding how to explore. Cheaper than `tree / -L 2` when you only need numbers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mount": {
            "description": "Optional: restrict to one mount. Omit for all.",
            "type": "string",
            "enum": [
              "/docs",
              "/memory",
              "/workspace"
            ]
          }
        },
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "bootedAt": {
            "type": "string"
          },
          "bootTimeMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "chunkCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "chunkBackend": {
            "type": "string",
            "enum": [
              "in-memory",
              "chroma"
            ]
          },
          "mounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "mount": {
                  "type": "string"
                },
                "fileCount": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "dirCount": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "totalBytes": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "lastWriteAt": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "writable": {
                  "type": "boolean"
                },
                "ttlHours": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "mount",
                "fileCount",
                "dirCount",
                "totalBytes",
                "lastWriteAt",
                "writable"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "bootedAt",
          "bootTimeMs",
          "chunkCount",
          "chunkBackend",
          "mounts"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "remember",
      "description": "Save a note to /memory/<slug>.md. <slug> is derived from `topic` (lowercased, punctuation stripped, spaces→hyphens, max 60 chars). This is the agent's persistence primitive — the only way findings survive across MCP sessions. Every write is tagged provenance source=\"tool\" with the session_id. Use for any fact you want a future session to pick up. For scratch work use /workspace instead (via the docs tool with `>` redirect).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Short human-readable topic. Gets slugified to the filename."
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65536,
            "description": "Markdown body. 64 KB cap."
          },
          "append": {
            "description": "If true, append to any existing file under this slug; otherwise overwrite. Default false.",
            "type": "boolean"
          },
          "note": {
            "description": "Optional free-form provenance note (e.g. `source query` or `why this matters`). Stored in nodes.provenance.note.",
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "topic",
          "content"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "path": {
            "type": "string"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "mode": {
            "type": "string",
            "enum": [
              "overwrite",
              "append"
            ]
          }
        },
        "required": [
          "ok",
          "path",
          "bytes",
          "mode"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    }
  ]
}