{
  "name": "docsvfs",
  "version": "0.1.0",
  "description": "A ChromaFS-inspired virtual filesystem for documentation. Give AI agents a Unix shell over your docs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docsvfs": "./dist/cli/main.js",
    "docsvfs-mcp": "./dist/mcp/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tool": {
      "import": "./dist/tool.js",
      "types": "./dist/tool.d.ts"
    },
    "./remember": {
      "import": "./dist/remember-tool.js",
      "types": "./dist/remember-tool.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli/main.js dist/mcp/bin.js",
    "dev": "tsc --watch",
    "start": "node dist/cli/main.js",
    "start:mcp": "node dist/mcp/bin.js",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "virtual-filesystem",
    "chromafs",
    "just-bash",
    "ai-agents",
    "documentation",
    "cli",
    "rag",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Rayan Castilla",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "chromadb": "^1.9.0",
    "chromadb-default-embed": "^2.14.0",
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "just-bash": "^2.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@types/node": "^22.0.0",
    "ai": "^6.0.156",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "demo-docs"
  ]
}
